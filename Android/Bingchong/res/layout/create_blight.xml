<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@drawable/bg"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtTitle"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="新发病虫害预警信息报审"
            android:textAppearance="?android:attr/textAppearanceLarge" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="10px"
        android:layout_weight="1"
        android:orientation="vertical" android:id="@+id/rlContent" android:layout_below="@+id/rlTitle">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10px" >

            <RadioGroup
                android:id="@+id/main_radio_group"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal" >

                <com.bingchong.widget.BRadioButton
                    android:id="@+id/btnNew"
                    style="@style/main_tab"
                    android:layout_height="45px"
                    android:checked="true"
                    android:text="新增"
                    android:textColor="@color/menuColor"
                    android:textSize="@dimen/NormalTextSize" android:layout_width="0px" android:layout_weight="1"/>

                <com.bingchong.widget.BRadioButton
                    android:id="@+id/btnInfo"
                    style="@style/main_tab"
                    android:layout_height="45px"
                    android:text="审核批复"
                    android:textColor="@color/menuColor" android:checked="false"
                    android:textSize="@dimen/NormalTextSize" android:layout_weight="1" android:layout_width="0px"/>
            </RadioGroup>
        </LinearLayout>

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_weight="1" android:layout_marginTop="10px">

            <include layout="@layout/create_blight_info" />

            <include layout="@layout/item_list" />
            <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="2px"
                    android:id="@+id/imageView" android:background="@color/menuColor"/>
        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>