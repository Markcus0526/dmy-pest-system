<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background1"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtView"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="折线图分析"
            android:textAppearance="?android:attr/textAppearanceLarge" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="50px"
        android:layout_marginLeft="10px"
        android:layout_marginRight="10px"
        android:layout_marginTop="15px"
        android:gravity="center"
        android:orientation="horizontal" android:id="@+id/rlDate" android:layout_below="@+id/rlTitle">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:layout_marginRight="6px"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="起"
                android:textColor="@color/menuColor"
                android:textSize="@dimen/NormalTextSize" />

            <com.bingchong.widget.DateTimePicker
                android:id="@+id/edt_sdate"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_margin="1px"
                android:layout_weight="1"
                android:gravity="center"
                android:paddingLeft="15px"
                android:textSize="@dimen/NormalTextSize" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="fill_parent"
            android:layout_marginLeft="6px"
            android:layout_weight="1" >

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="终"
                android:textColor="@color/menuColor"
                android:textSize="@dimen/NormalTextSize" />

            <com.bingchong.widget.DateTimePicker
                android:id="@+id/edt_edate"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_margin="1px"
                android:layout_weight="1"
                android:gravity="center"
                android:inputType="date"
                android:paddingLeft="15px"
                android:textColor="@color/menuTxtColor"
                android:textSize="@dimen/NormalTextSize" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10px"
        android:orientation="vertical" android:id="@+id/rlFilter" android:layout_below="@+id/rlDate">

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="50px" >

            <Spinner
                android:id="@+id/spinner_sheng"
                style="@style/Spinner"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_margin="3px"
                android:layout_weight="1"/>

            <Spinner
                android:id="@+id/spinner_shi"
                style="@style/Spinner"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_margin="3px"
                android:layout_weight="1"/>

            <Spinner
                android:id="@+id/spinner_xian"
                style="@style/Spinner"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_margin="3px"
                android:layout_weight="1"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="50px" >

            <Spinner
                android:id="@+id/spinner_point"
                style="@style/Spinner"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_margin="3px"
                android:layout_weight="1"/>

            <Spinner
                android:id="@+id/spinner_blight"
                style="@style/Spinner"
                android:layout_width="wrap_content"
                android:layout_height="fill_parent"
                android:layout_margin="3px"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout android:layout_width="fill_parent" android:layout_height="70px">
            <Spinner style="@style/Spinner" android:id="@+id/spinner_form" android:layout_width="wrap_content"
                     android:layout_height="fill_parent" android:layout_margin="3px" android:layout_weight="1"
                    />
            <Spinner style="@style/Spinner" android:id="@+id/spinner_field" android:layout_width="wrap_content"
                     android:layout_height="fill_parent" android:layout_margin="3px" android:layout_weight="1"
                    />
            <Button
                    android:layout_width="100px"
                    android:layout_height="match_parent"
                    android:text="搜索"
                    android:id="@+id/btnSearch" android:textSize="25px" style="@style/main_btn"
                    android:layout_margin="3px"/>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_graph"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="10px"
        android:orientation="vertical" android:layout_below="@+id/rlFilter">
    </LinearLayout>

</RelativeLayout>