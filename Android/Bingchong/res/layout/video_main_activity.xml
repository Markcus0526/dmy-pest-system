<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

    <RelativeLayout android:layout_width="fill_parent" android:layout_height="@dimen/TitleBarSize"
                    android:id="@+id/rlTitle" android:background="@color/menuColor">
        <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="视频通话"
                  android:id="@+id/textView4" android:textColor="#FFFFFF" android:textSize="@dimen/TitleTextSize"
                  android:gravity="center"/>
        <ImageButton android:layout_width="70px" android:layout_height="match_parent" android:id="@+id/btn_back"
                     android:background="@null" android:scaleType="centerInside" android:src="@drawable/btn_back"
                     android:padding="15px"/>
    </RelativeLayout>
    <RelativeLayout android:layout_width="fill_parent" android:layout_height="fill_parent"
                    android:id="@+id/rlContent" android:layout_below="@+id/rlTitle"
                    android:background="@color/background">
    </RelativeLayout>
</RelativeLayout>