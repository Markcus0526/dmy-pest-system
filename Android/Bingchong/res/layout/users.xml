<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtTitle"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="测报员基本信息"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="120px"
        android:layout_marginLeft="20px"
        android:layout_marginRight="20px"
        android:layout_marginTop="10px"
        android:orientation="horizontal" android:id="@+id/rlFilter" android:layout_below="@+id/rlTitle">

        <TextView
            android:id="@+id/lbl_level"
            android:layout_width="wrap_content"
            android:layout_height="50px"
            android:layout_gravity="left|center_vertical"
            android:text="级别："
            android:textColor="@color/menuColor"
            android:textSize="@dimen/NormalTextSize" android:gravity="center"/>

        <Spinner
            android:id="@+id/spinner_level"
            android:layout_width="match_parent"
            android:layout_height="50px"
            android:layout_weight="1"
            android:background="@drawable/btn_dropdown" android:layout_alignParentRight="true"
            android:layout_toRightOf="@+id/lbl_level" android:layout_marginLeft="10px"/>

        <Spinner android:id="@+id/spinner_sheng" android:layout_width="150px" android:layout_height="70px"
                 android:background="@color/menuColor" android:paddingLeft="5px"
                 android:layout_alignParentRight="false"
                 android:layout_marginTop="10px" android:layout_below="@+id/lbl_level"/>
        <Spinner android:id="@+id/spinner_shi" android:layout_width="150px" android:layout_height="70px"
                 android:background="@color/menuColor" android:paddingLeft="5px"
                 android:layout_marginLeft="10px" android:layout_toRightOf="@+id/spinner_sheng"
                 android:layout_alignParentRight="false" android:layout_alignTop="@+id/spinner_sheng"/>
        <Spinner android:id="@+id/spinner_xian" android:layout_width="200px" android:layout_height="70px"
                 android:background="@color/menuColor" android:paddingLeft="5px"
                 android:layout_marginLeft="10px" android:layout_toRightOf="@+id/spinner_shi"
                 android:layout_alignParentRight="true"
                 android:layout_alignTop="@+id/spinner_sheng"/>

    </RelativeLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical" android:id="@+id/rlContent" android:layout_below="@+id/rlFilter"
        android:layout_marginLeft="20px" android:layout_marginRight="20px" android:layout_marginBottom="10px"
        android:layout_marginTop="10px">

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" >

                <ListView
                    android:id="@+id/list_data"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:divider="@null" />

            </LinearLayout>

            <TextView
                android:id="@+id/txt_no_content"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/strNoContent"
                android:textSize="22sp"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>