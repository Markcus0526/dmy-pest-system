<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtViewSearch"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="通知"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="50px"
        android:layout_marginLeft="15px"
        android:layout_marginRight="15px"
        android:layout_marginTop="10px"
        android:gravity="center"
        android:orientation="horizontal" android:id="@+id/rlYear" android:layout_below="@+id/rlTitle">

        <TextView
            android:id="@+id/textView1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="left|center_vertical"
            android:text="年度选择:"
            android:textColor="@color/menuColor"
            android:textSize="@dimen/NormalTextSize" />

        <Spinner
            android:id="@+id/spinnerPos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/btn_dropdown" android:layout_marginLeft="20px"/>

    </LinearLayout>

    <LinearLayout android:layout_width="fill_parent" android:layout_height="50px" android:layout_marginLeft="15px"
                  android:layout_marginRight="15px" android:layout_marginTop="10px" android:gravity="center"
                  android:orientation="horizontal" android:id="@+id/rlType" android:layout_below="@+id/rlYear">
        <TextView android:id="@+id/textView17" android:layout_width="wrap_content" android:layout_height="wrap_content"
                  android:layout_gravity="left|center_vertical" android:text="通   知:"
                  android:textColor="@color/menuColor" android:textSize="@dimen/NormalTextSize"/>
        <Spinner android:id="@+id/spinner_type" android:layout_width="wrap_content" android:layout_height="wrap_content"
                 android:layout_weight="1" android:background="@drawable/btn_dropdown"
                 android:layout_marginLeft="20px"/>
        <Button
                android:layout_width="120px"
                android:layout_height="match_parent"
                android:text="发布通知"
                android:id="@+id/btn_publish" android:layout_marginLeft="20px" android:textSize="20px"
                style="@style/main_btn"/>
    </LinearLayout>
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:layout_margin="15px"
        android:layout_marginBottom="20px"
        android:layout_weight="1"
        android:orientation="vertical" android:id="@+id/rlContent" android:layout_below="@+id/rlType">

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_marginBottom="10px"
            android:layout_marginTop="10px"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" >

                <ListView
                    android:id="@+id/list_data"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"

                    android:divider="@null" />                    

            </LinearLayout>

            <TextView
                android:id="@+id/txt_no_content"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/strNoContent"
                android:textSize="22sp"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>