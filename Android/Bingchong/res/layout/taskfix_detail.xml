<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background1"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/LinearLayout2"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtViewSearch"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="常规测报工作详情"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_margin="10px"
        android:orientation="vertical" >

        <com.bingchong.widget.LineView
            android:layout_width="wrap_content"
            android:layout_height="1px" />

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_weight="1" >

            <com.bingchong.widget.LineView
                android:layout_width="1px"
                android:layout_height="fill_parent" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_weight="1"
                android:orientation="vertical" >

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="测报点名称"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText01"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white" />
                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="病虫害类别"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <Spinner
                            android:id="@+id/spinnerSex"
                            android:layout_width="wrap_content"
                            android:layout_height="fill_parent"
                            android:layout_weight="1"
                            android:background="@color/white" />

                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="名称"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText03"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white"
                            android:inputType="datetime" >

                            <requestFocus />
                        </EditText>
                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="开始时间"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText04"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white" />
                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="结束时间"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText05"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white" />
                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="测报表格"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText06"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white" />
                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" >

                        <TextView
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="发布单位"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />

                        <com.bingchong.widget.LineView
                            android:layout_width="1px"
                            android:layout_height="fill_parent" />

                        <EditText
                            android:id="@+id/EditText07"
                            android:layout_width="fill_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:layout_weight="1"
                            android:background="@color/white"
                            android:inputType="phone" />

                    </LinearLayout>

                    <com.bingchong.widget.LineView
                        android:layout_width="wrap_content"
                        android:layout_height="1px" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:layout_weight="1"
                    android:orientation="vertical" >

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" >

                        <TextView
                            android:id="@+id/TextView01"
                            android:layout_width="120px"
                            android:layout_height="wrap_content"
                            android:layout_margin="3px"
                            android:text="备注"
                            android:textAppearance="?android:attr/textAppearanceLarge"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/NormalTextSize" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="fill_parent"
                        android:layout_height="fill_parent" >

                        <TextView
                            android:id="@+id/textView1"
                            android:layout_width="fill_parent"
                            android:layout_height="fill_parent"
                            android:layout_weight="1"
                            android:text="TextView" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <com.bingchong.widget.LineView
                android:layout_width="1px"
                android:layout_height="fill_parent" />
        </LinearLayout>

        <com.bingchong.widget.LineView
            android:layout_width="wrap_content"
            android:layout_height="1px" />

    </LinearLayout>

</LinearLayout>