<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" android:focusableInTouchMode="false">

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtTitle"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="历史工作"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <RadioGroup
        android:id="@+id/main_radio_group"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="false"
        android:layout_marginBottom="15px"
        android:layout_marginTop="50px"
        android:gravity="center_vertical"
        android:orientation="horizontal" android:layout_below="@+id/rlTitle">

        <com.bingchong.widget.BRadioButton
            android:id="@+id/btnNoComplete"
            style="@style/main_tab"
            android:layout_height="45px"
            android:checked="true"
            android:text="未完成工作" />

        <com.bingchong.widget.BRadioButton
            android:id="@+id/btnComplete"
            style="@style/main_tab"
            android:layout_height="45px"
            android:text="已完成工作" />

    </RadioGroup>

    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1" android:id="@+id/rlContent" android:layout_below="@+id/main_radio_group">
		<include layout="@layout/item_list" />
	</RelativeLayout>
    

</RelativeLayout>