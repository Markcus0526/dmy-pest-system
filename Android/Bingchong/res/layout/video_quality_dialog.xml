<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:minWidth="280dip"
    android:background="@null">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue"
        android:paddingTop="10dip"
        android:paddingBottom="10dip"
        android:orientation="horizontal" >
		
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ffffff"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="8dip"
            android:textSize="20sp"
            />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/content"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:minHeight="100dip"
        android:background="@drawable/bg_middle_custom_serach_add_dialog"
        android:orientation="vertical" 
        android:gravity="center">

        <LinearLayout 
            android:id="@+id/ll_1"
            android:layout_width="fill_parent"
            android:orientation="horizontal"
            android:layout_height="45dp"
            android:gravity="center_vertical"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp"
            
            
            >
            <TextView 
				android:id="@+id/tv1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/low_quality"
                android:textColor="@color/black"
                android:textSize="20sp"
                />
            <TextView 
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                />
            <ImageButton
                android:id="@+id/iv1"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="fitXY"
                android:src="@drawable/fw002"
                android:background="@null"
                />
        </LinearLayout>
        <TextView 
                android:layout_width="fill_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="0dp"
                android:background="#99000000"
                />   
        <LinearLayout 
            android:id="@+id/ll_2"
            android:layout_width="fill_parent"
            android:orientation="horizontal"
            android:layout_height="45dp"
            android:gravity="center_vertical"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp"
            
            
            >
            <TextView 
                android:id="@+id/tv2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/middle_quality"
                android:textSize="20sp"
                android:textColor="@color/black"
                />
            <TextView 
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                />
            <ImageButton 
                android:id="@+id/iv2"
                 android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="fitXY"
                android:src="@drawable/fw001"
                android:background="@null"
                />
        </LinearLayout>
        <TextView 
                android:layout_width="fill_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="0dp"
                android:background="#99000000"
                />   
        <LinearLayout 
            android:id="@+id/ll_3"
            android:layout_width="fill_parent"
            android:orientation="horizontal"
            android:layout_height="45dp"
            android:gravity="center_vertical"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp"
            
            
            >
            <TextView 
                android:id="@+id/tv3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/high_quality"
                android:textColor="@color/black"
                android:textSize="20sp"
                />
            <TextView 
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                />
            <ImageButton 
                android:id="@+id/iv3"
                 android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="fitXY"
                android:src="@drawable/fw001"
                android:background="@null"
                />
        </LinearLayout>
         <TextView 
                android:layout_width="fill_parent"
                android:layout_height="0.5dp"
                android:layout_marginTop="0dp"
                android:background="#99000000"
                />      
        <!-- <LinearLayout 
            android:id="@+id/ll_4"
            android:layout_width="fill_parent"
            android:orientation="horizontal"
            android:layout_height="45dp"
            android:gravity="center_vertical"
            android:layout_marginLeft="35dp"
            android:layout_marginRight="35dp"
            
            
            >
            <TextView 
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="附近5千米"
                android:textSize="20sp"
                />
            <TextView 
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="1dp"
                />
            <ImageButton 
                 android:id="@+id/iv4"
                  android:layout_width="25dp"
                android:layout_height="25dp"
                android:scaleType="fitXY"
                android:src="@drawable/fw001"
                android:background="@null"
                />
        </LinearLayout> -->  
        
    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingTop="5dip"
        android:paddingLeft="5dip"
        android:paddingRight="5dip"
		android:background="@drawable/bg_middle_custom_serach_add_dialog"
		android:orientation="horizontal" >

        <Button
            android:layout_margin="10dp"
            android:textSize="20sp"
            android:id="@+id/positiveButton"
            android:layout_width="0dip"
            android:layout_height="45dp"
            android:textColor="@color/white"
            android:layout_weight="1"
            android:background="@drawable/btn_login"
            android:singleLine="true" />

        <Button
            android:layout_margin="10dp"
            android:textSize="20sp"
            android:id="@+id/negativeButton"
            android:layout_width="0dip"
            android:layout_height="45dp"
            android:layout_marginLeft="3dip"
            android:textColor="@color/white"
            android:layout_weight="1"
            android:background="@drawable/btn_login"
            android:singleLine="true" />
    </LinearLayout>

</LinearLayout>