<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/parent_layout"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/background"
    android:orientation="vertical" >

    <LinearLayout
        android:id="@+id/rlTitle"
        android:layout_width="fill_parent"
        android:layout_height="@dimen/TitleBarSize"
        android:background="@color/menuColor"
        android:orientation="horizontal" >

        <ImageButton
                android:layout_width="70px"
                android:layout_height="match_parent"
                android:id="@+id/btn_back" android:background="@null" android:scaleType="centerInside"
                android:src="@drawable/btn_back" android:padding="15px"/>

        <TextView
            android:id="@+id/txtTitle"
            style="@style/TopText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|right|center_horizontal"
            android:layout_weight="1"
            android:gravity="center"
            android:text="病虫害基本信息管理"
            android:textAppearance="?android:attr/textAppearanceLarge" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="50px"
        android:layout_marginLeft="20px"
        android:layout_marginRight="20px"
        android:layout_marginTop="20px"
        android:gravity="center"
        android:orientation="horizontal" android:id="@+id/rlSearch" android:layout_below="@+id/rlTitle">

        <Spinner
            android:id="@+id/spinner_blight_type"
            android:layout_width="120px"
            android:layout_height="fill_parent"
            android:layout_marginRight="10px"
            android:background="@color/menuColor"
            android:prompt="@string/select_blight_type"
            android:textSize="18px" />

        <LinearLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:layout_weight="1"
            android:background="@drawable/item_rect_normal"
            android:gravity="center"
            android:orientation="horizontal" >

            <Button
                android:id="@+id/btn_search"
                android:layout_width="50px"
                android:layout_height="match_parent"
                android:layout_margin="1px"
                android:background="@drawable/search"
                android:gravity="center"
                android:paddingLeft="15px"
                android:paddingRight="15px"
                android:textSize="30px" />

            <EditText
                android:id="@+id/edt_search_str"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_margin="1px"
                android:layout_weight="1"
                android:background="@color/white"
                android:hint="输入病虫害名称"
                android:imeOptions="actionSearch"
                android:inputType="textPersonName"
                android:paddingLeft="2px"
                android:textColor="@color/menuColor"
                android:textColorHint="@color/menuColor"
                android:textSize="@dimen/NormalTextSize" >

                <requestFocus />
            </EditText>
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="10px"
        android:layout_weight="1"
        android:orientation="vertical" android:id="@+id/rlContent" android:layout_below="@+id/rlSearch"
        android:layout_marginLeft="20px" android:layout_marginRight="20px" android:layout_marginTop="10px">

        <RelativeLayout
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:orientation="vertical" >

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" >

                <ListView
                    android:id="@+id/list_data"
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent"
                    android:layout_weight="1"
                    android:divider="@null" >                    
                </ListView>
            </LinearLayout>

            <TextView
                android:id="@+id/txt_no_content"
                android:layout_width="fill_parent"
                android:layout_height="fill_parent"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="@string/strNoContent"
                android:textSize="22sp"
                android:visibility="gone" />
        </RelativeLayout>
    </LinearLayout>

</RelativeLayout>