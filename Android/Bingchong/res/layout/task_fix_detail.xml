<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:id="@+id/parent_layout"
                android:background="@color/background">

    <LinearLayout android:id="@+id/rlTitle" android:layout_width="fill_parent"
                  android:layout_height="@dimen/TitleBarSize" android:background="@color/menuColor"
                  android:orientation="horizontal">
        <ImageButton android:layout_width="70px" android:layout_height="match_parent" android:id="@+id/btn_back"
                     android:background="@null" android:scaleType="centerInside" android:src="@drawable/btn_back"
                     android:padding="15px"/>
        <TextView style="@style/TopText" android:id="@+id/txtTitle" android:layout_width="wrap_content"
                  android:layout_height="wrap_content" android:layout_gravity="center|right|center_horizontal"
                  android:layout_weight="1" android:gravity="center" android:text="常规测报工作详情"
                />
        <Button android:id="@+id/btnReport" android:layout_width="70px" android:layout_height="50px"
                android:layout_gravity="center" android:layout_marginRight="15px" android:background="@drawable/btn_top"
                android:text="上报" android:textColor="@color/menuTxtColor" android:textSize="@dimen/MenuTextSize"/>
    </LinearLayout>
    <ScrollView
            android:layout_width="fill_parent"
            android:layout_height="fill_parent"
            android:id="@+id/scroll_view" android:layout_below="@+id/rlTitle" android:layout_margin="15px">

        <RelativeLayout
                android:layout_width="fill_parent"
                android:layout_height="fill_parent" android:id="@+id/rlContent" android:layout_below="@+id/rlTitle">
            <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:id="@+id/rlPointInfo">
                <WebView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/wvPointInfo"/>
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="50px" android:id="@+id/rlPointNo" android:layout_below="@+id/rlPointInfo"
                    android:layout_marginTop="10px">
                <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:id="@+id/imgPointType" android:src="@drawable/place_mark"
                        android:layout_marginLeft="-10px"/>
                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="New Text"
                        android:id="@+id/txtPointNo"
                        android:layout_toRightOf="@+id/imgPointType" android:gravity="center_vertical"
                        android:textSize="@dimen/MenuTextSize"/>
            </RelativeLayout>
            <RelativeLayout
                    android:layout_width="fill_parent"
                    android:layout_height="fill_parent" android:id="@+id/rlReportInfo" android:layout_below="@+id/rlPointNo"
                    android:layout_marginTop="10px">
                <RadioGroup
                        android:id="@+id/main_radio_group"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="horizontal" >

                    <com.bingchong.widget.BRadioButton
                            android:id="@+id/btnTable"
                            style="@style/main_tab"
                            android:layout_height="45px"
                            android:checked="true"
                            android:text="测报表格"
                            android:textColor="@color/menuColor"
                            android:textSize="@dimen/MenuTextSize" />

                    <com.bingchong.widget.BRadioButton
                            android:id="@+id/btnInfo"
                            style="@style/main_tab"
                            android:layout_height="45px"
                            android:text="病虫基本信息"
                            android:textColor="@color/menuColor" android:textSize="@dimen/MenuTextSize"/>
                </RadioGroup>
                <include layout="@layout/report_blight_table" android:layout_width="fill_parent"
                         android:layout_height="wrap_content" android:layout_below="@+id/main_radio_group"/>
                <include layout="@layout/report_blight_info" android:layout_width="fill_parent"
                         android:layout_height="wrap_content" android:layout_below="@+id/main_radio_group"/>
            </RelativeLayout>
        </RelativeLayout>
    </ScrollView>
</RelativeLayout>